{
  "name": "claudex",
  "version": "0.2.1",
  "private": true,
  "description": "Launch the genuine Claude Code harness with GPT-5.6 Sol through Codex OAuth.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cobibean/claudex.git"
  },
  "homepage": "https://github.com/cobibean/claudex#readme",
  "bugs": {
    "url": "https://github.com/cobibean/claudex/issues"
  },
  "keywords": [
    "claude-code",
    "codex",
    "oauth",
    "cli",
    "proxy"
  ],
  "type": "module",
  "bin": {
    "claudex": "bin/claudex"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:upstreams": "pnpm build && node scripts/check-upstreams.mjs",
    "certify:claude": "pnpm build && node scripts/certify-claude.mjs",
    "release:manifest": "node scripts/release-manifest.mjs generate",
    "release:sign": "node scripts/release-manifest.mjs sign",
    "release:verify": "node scripts/release-manifest.mjs verify",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "pnpm run build"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.33.1"
}
